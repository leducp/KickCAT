prefix=@PC_PREFIX@
exec_prefix=${prefix}
libdir=@PC_LIBDIR@
includedir=@PC_INCLUDEDIR@

Name: KickCAT
Description: EtherCAT master/slave stack
Version: @PROJECT_VERSION@
Requires.private:@PC_REQUIRES_PRIVATE@
Libs: -L${libdir} -lkickcat -lkickcat_time
Libs.private:@PC_LIBS_PRIVATE@
Cflags: -I${includedir}@PC_CFLAGS_EXTRA@
